      "seed": 1395376807,
      "version": 67,
      "versionNonce": 1854372230,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773153173239,
      "link": null,
      "locked": false,
      "text": "Build a privacy-preserving application on top of BitGo's wallet\ninfrastructure.\nUsing BitGo's SDK and testnet, you can create wallets, generate fresh\naddresses per transaction, build and sign transactions programmatically,\nenforce policies, and leverage webhooks. This could be a stealth-address\npayment system that disburses funds from a BitGo wallet to unlinkable\nrecipient addresses, a ZK-proof layer that gates access to DeFi protocols\nwithout revealing the wallet owner's identity, private multi-sig governance\nwhere signer votes stay encrypted until threshold is met, or any creative\napproach to on-chain privacy built on BitGo wallets.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "mYoKP6A8EP7jsLpiWqzf2",
      "originalText": "Build a privacy-preserving application on top of BitGo's wallet infrastructure.\nUsing BitGo's SDK and testnet, you can create wallets, generate fresh addresses per transaction, build and sign transactions programmatically, enforce policies, and leverage webhooks. This could be a stealth-address payment system that disburses funds from a BitGo wallet to unlinkable recipient addresses, a ZK-proof layer that gates access to DeFi protocols without revealing the wallet owner's identity, private multi-sig governance where signer votes stay encrypted until threshold is met, or any creative approach to on-chain privacy built on BitGo wallets.",
      "autoResize": true,
      "lineHeight": 1.25
    },
