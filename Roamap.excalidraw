    {
      "id": "4locisD2Ye-OYOJF6IZgy",
      "type": "text",
      "x": 12596.05217225191,
      "y": 6981.24215070745,
      "width": 326.459716796875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0X3",
