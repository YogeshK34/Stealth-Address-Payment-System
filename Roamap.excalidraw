    {
      "id": "IIi2_0AI61OIfG-JnY41h",
      "type": "text",
      "x": 12374.80834227168,
      "y": 6115.111676752758,
      "width": 734.7791748046875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
